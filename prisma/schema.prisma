datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

model Guide {
  id         String    @id @default(uuid())
  name       String
  avatar     String
  rating     Float
  experience String
  bio        String
}

model Destination {
  id                 String              @id @default(uuid())
  name               String
  slug               String              @unique
  description        String
  heroImage          String
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  stops              Stop[]
  itineraryTemplates ItineraryTemplate[]
}

model Stop {
  id            String      @id @default(uuid())
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  locationName  String
  sequenceOrder Int
  defaultNights Int
  description   String
  hotels        Hotel[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Hotel {
  id          String   @id @default(uuid())
  stopId      String
  stop        Stop     @relation(fields: [stopId], references: [id], onDelete: Cascade)
  name        String
  starRating  Float
  isConfirmed Boolean  @default(false)
  image       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ItineraryTemplate {
  id            String      @id @default(uuid())
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  durationDays  Int // 3, 5, or 7
  title         String
  price         Float
  difficulty    String
  image         String
  itineraryJson String // JSON describing activities and stops day-by-day
  included      String[]
  excluded      String[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String
  destination String?
  date        String?
  guests      String?
  notes       String?
  formType    String   @default("itinerary") // "itinerary" or "general"
  submittedAt DateTime @default(now())
}

model PartnerApplication {
  id              String   @id @default(uuid())
  name            String
  email           String
  phone           String
  companyName     String?
  partnershipType String
  message         String?
  submittedAt     DateTime @default(now())
}
